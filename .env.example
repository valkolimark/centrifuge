# ─────────────────────────────────────────────────────────────
# Centrifuge.com environment variables
# Copy to .env.local and fill in. Cycle 1 runs with placeholders;
# integration tests are deferred until real secrets are present.
# ─────────────────────────────────────────────────────────────

# Public site URL (canonical). Used for metadata, sitemap, canonicals.
NEXT_PUBLIC_SITE_URL=https://centrifuge.com

# Payload CMS
PAYLOAD_SECRET=replace-with-a-long-random-string
# Neon Postgres connection string (@payloadcms/db-postgres)
DATABASE_URI=postgres://user:password@host/db?sslmode=require

# Vercel Blob storage (media adapter)
BLOB_READ_WRITE_TOKEN=

# Resend (transactional email + form notifications)
RESEND_API_KEY=
# From address used for all outbound mail
RESEND_FROM_EMAIL=notifications@centrifuge.com

# Twilio Email operator (Leads & Quotes, UI-2) — POST comms.twilio.com/v1/Emails.
# Prefer a scoped API Key (SID+Secret); Account SID+Auth Token is the dev fallback.
# Sender domain centrifuge.com + senders notifications@ / quotes@ must be VERIFIED in
# the Twilio Email console or every send fails (see README).
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Safety: keep true everywhere except a deliberate, approved live smoke test. When true
# (or when credentials are absent) the operator logs payloads and sends NO real email.
LEADS_EMAIL_DRY_RUN=true

# Cloudflare Turnstile (invisible anti-spam)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Analytics — Google Tag Manager (loaded after interactive)
NEXT_PUBLIC_GTM_ID=GTM-P5VRJC5

# Mission Control analytics (GA4 Data API) — optional; dashboard shows empty state without them
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=
