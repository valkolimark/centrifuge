# ─────────────────────────────────────────────────────────────
# Centrifuge.com environment variables
# Copy to .env.local and fill in. Cycle 1 runs with placeholders;
# integration tests are deferred until real secrets are present.
# ─────────────────────────────────────────────────────────────

# Public site URL (canonical). Used for metadata, sitemap, canonicals.
NEXT_PUBLIC_SITE_URL=https://centrifuge.com

# Payload CMS
PAYLOAD_SECRET=replace-with-a-long-random-string
# Neon Postgres connection string (@payloadcms/db-postgres)
DATABASE_URI=postgres://user:password@host/db?sslmode=require

# Vercel Blob storage (media adapter)
BLOB_READ_WRITE_TOKEN=

# Resend (transactional email + form notifications)
RESEND_API_KEY=
# From address used for all outbound mail
RESEND_FROM_EMAIL=notifications@centrifuge.com

# Cloudflare Turnstile (invisible anti-spam)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Analytics — Google Tag Manager (loaded after interactive)
NEXT_PUBLIC_GTM_ID=GTM-P5VRJC5
