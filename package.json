{
  "name": "centrifuge-com",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Centrifuge.com rebuild — Next.js 15 + Payload CMS 3.x",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build:redirects": "tsx scripts/build-redirects.ts",
    "prebuild": "pnpm build:redirects",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:contrast": "tsx scripts/check-contrast.ts",
    "payload": "payload",
    "seed": "tsx scripts/seed.ts",
    "generate:types": "pnpm payload generate:types",
    "generate:importmap": "pnpm payload generate:importmap",
    "verify": "pnpm typecheck && pnpm check:contrast && pnpm test"
  },
  "dependencies": {
    "@next/third-parties": "^15.1.6",
    "@payloadcms/db-postgres": "^3.85.2",
    "@payloadcms/email-resend": "^3.85.2",
    "@payloadcms/next": "^3.85.2",
    "@payloadcms/richtext-lexical": "^3.85.2",
    "@payloadcms/storage-vercel-blob": "^3.85.2",
    "graphql": "^16.14.2",
    "next": "15.1.6",
    "payload": "^3.85.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.33.5",
    "zod": "^3.24.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver",
      "@vercel/speed-insights"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.17.12",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.1.6",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
